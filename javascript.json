{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>24dlong/renovate-config//base.json"],
  "packageRules": [
    {
      "description": "Group vitest dependencies together",
      "matchPackagePatterns": ["^vitest$", "^@vitest/"],
      "matchUpdateTypes": ["major"],
      "groupName": "vitest-dependencies"
    },
    {
      "description": "Group react dependencies together",
      "matchPackagePatterns": ["react"],
      "groupName": "react-dependencies"
    },
    {
      "description": "Group typescript dependencies together",
      "matchPackagePatterns": ["^typescript$", "^typescript-eslint$", "^@typescript-eslint/"],
      "groupName": "typescript-dependencies"
    },
    {
      "description": "Exclude Storybook dependencies from Renovate",
      "matchPackagePatterns": ["storybook", "chromatic"],
      "enabled": false
    }
  ]
}
