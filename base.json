{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "7 days",
  "hostRules": [
    {
      "matchHost": "dlong-081924037451.d.codeartifact.us-east-2.amazonaws.com",
      "hostType": "npm",
      "token": "{{ env.CODEARTIFACT_AUTH_TOKEN }}"
    }
  ],
  "packageRules": [
    {
      "description": "Group minor and patch updates together",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor-updates"
    },
    {
      "description": "Skip minimum release age for private registry packages",
      "matchRegistryUrls": ["https://dlong-081924037451.d.codeartifact.us-east-2.amazonaws.com"],
      "minimumReleaseAge": "0 days"
    }
  ],
  "automerge": false
}
